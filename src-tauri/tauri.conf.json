{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ComicSlicer",
  "version": "0.1.5",
  "identifier": "com.comic.caijian",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ComicSlicer",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNTkyRkMzQkJGRkM3MzkKUldRNXgvKzd3eTlaZ1ZrQTVzTW5nMTMvTzBqL29zdStwMHJBSkNUN3d3MVliRUsyeFJtblNwRXgK",
      "endpoints": [
        "https://github.com/Liboq/ComicSlicer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
